rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document IDs (usernames)
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection rules
    match /users/{username} {
      allow get: if isValidId(username);
      allow create: if isValidId(username) 
                    && request.resource.data.username == username;
      allow update: if isValidId(username);
      allow delete: if false; // Profiles shouldn't be deleted via client SDK
    }

    // UserData collection rules
    match /userData/{username} {
      allow get: if isValidId(username);
      allow create, update: if isValidId(username);
      allow delete: if false;
    }
  }
}
